# Environment Variables Template for Production

# Generate secure keys with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"

# ========================
# SECURITY BACKEND
# ========================

SECURITY_SECRET_KEY=your-unique-secret-key-min-32-chars
SECURITY_DATABASE_URL=postgresql://security_user:secure-password@security-db:5432/security_db

# ========================
# CROSS-SERVICE INTEGRATION
# ========================

API_INTEGRATION_KEY=your-api-integration-key-min-32-chars
API_INTEGRATION_SECRET=your-api-integration-secret-min-32-chars
ADMIN_API_KEY=your-admin-key-min-32-chars

# ========================
# SHOWWISE MAIN APP
# ========================

SHOWWISE_SECRET_KEY=your-showwise-secret-key-min-32-chars
DATABASE_URL=postgresql://showwise_user:showwise-password@showwise-db:5432/showwise_db
SECURITY_BACKEND_URL=http://security-backend:5000
APP_INSTANCE_NAME=main

# ========================
# SHOWWISE HOME
# ========================

HOME_SECRET_KEY=your-home-secret-key-min-32-chars
SECURITY_BACKEND_URL=http://security-backend:5000
APP_INSTANCE_NAME=home

# ========================
# CLOUDFLARE TURNSTILE
# ========================

CLOUDFLARE_SITE_KEY=your-turnstile-site-key-from-cloudflare
CLOUDFLARE_SECRET=your-turnstile-secret-from-cloudflare

# ========================
# SECURITY SETTINGS
# ========================

CHECK_CLOUDFLARE_THREAT=True
BLOCK_SCANNERS=True
SANITIZE_INPUT=True
REQUIRE_IP_CHECK=True

# IP Block Threshold (threat score: 0-100)
IP_BLOCK_THRESHOLD=80
RATE_LIMIT_WINDOW=3600
RATE_LIMIT_MAX_REQUESTS=1000

# Appeal Settings
APPEAL_EXPIRY_DAYS=30
QUARANTINE_AUTO_RELEASE_DAYS=90

# ========================
# OPTIONAL: EXTERNAL INTEGRATIONS
# ========================

# Sentry (error tracking)
SENTRY_DSN=

# Elasticsearch (logging)
ELASTICSEARCH_URL=

# Slack (alerts)
SLACK_WEBHOOK_URL=

# MaxMind GeoIP (geo-location)
MAXMIND_LICENSE_KEY=
