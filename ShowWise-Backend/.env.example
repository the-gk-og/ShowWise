# ShowWise Backend Configuration
# Copy this to .env and fill in your values

# ==================== SECURITY ====================
# IMPORTANT: Generate a strong secret key for production
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-here-change-this-in-production

# Database URL
# SQLite: sqlite:///showwise.db
# PostgreSQL: postgresql://user:password@localhost/showwise
# MySQL: mysql+pymysql://user:password@localhost/showwise
DATABASE_URL=sqlite:///showwise.db

# ==================== FLASK ====================
FLASK_ENV=production
FLASK_APP=app_db.py
PORT=5000

# CORS Origins (comma-separated)
CORS_ORIGINS=https://your-domain.com,https://another-domain.com

# ==================== OAUTH (OPTIONAL) ====================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ==================== SECURITY SETTINGS ====================
# Session timeout in hours
SESSION_TIMEOUT=12

# Maximum failed login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Account lockout duration in minutes
LOCKOUT_DURATION=30

# Password minimum length
MIN_PASSWORD_LENGTH=12

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FILE=logs/showwise.log

# ==================== SSL/TLS ====================
# For production, use proper certificates
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem
